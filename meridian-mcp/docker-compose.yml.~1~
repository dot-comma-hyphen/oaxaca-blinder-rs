version: '3.8'

services:
  meridian-mcp:
    build:
      context: ..
      dockerfile: meridian-mcp/Dockerfile
    container_name: meridian_mcp
    ports:
      - "8085:8084"
    environment:
      - PORT=8084
      - MCP_TRANSPORT=sse
      - MCP_API_KEY=dev-secret-key
    restart: unless-stopped
